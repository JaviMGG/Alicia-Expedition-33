  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Maelle: Comentarios",
        "scope": [
          "comment",
          "punctuation.definition.comment",
          "string.comment"
        ],
        "settings": { "foreground": "#6e6a6a", "fontStyle": "italic" }
      },
      {
        "name": "Maelle: Cadenas de texto (Strings)",
        "scope": [
          "string",
          "punctuation.definition.string"
        ],
        "settings": { "foreground": "#659e7a" }
      },
      {
        "name": "Maelle: Palabras Clave (Keywords)",
        "scope": [
          "keyword",
          "keyword.control",
          "storage.type",
          "storage.modifier",
          "variable.language"
        ],
        "settings": { "foreground": "#b85151" }
      },
      {
        "name": "Maelle: Funciones y Métodos",
        "scope": [
          "entity.name.function",
          "support.function",
          "meta.function-call"
        ],
        "settings": { "foreground": "#e6c47a" }
      },
      {
        "name": "Maelle: Variables generales",
        "scope": [
          "variable",
          "variable.other",
          "variable.parameter"
        ],
        "settings": { "foreground": "#d0dbdc" }
      },
      {
        "name": "Maelle: Números y Booleanos",
        "scope": [
          "constant.numeric",
          "constant.language.boolean",
          "constant.character"
        ],
        "settings": { "foreground": "#a86b61" }
      },
      {
        "name": "Maelle: Operadores y Puntuación",
        "scope": [
          "keyword.operator",
          "punctuation.separator",
          "punctuation.terminator",
          "punctuation.bracket"
        ],
        "settings": { "foreground": "#8c7a6b" }
      },
      {
        "name": "Maelle: Atributos y Propiedades",
        "scope": [
            "entity.other.attribute-name",
            "variable.other.property",
            "variable.other.object.property"
        ],
        "settings": { "foreground": "#c7ae7f" }
      },
      {
        "name": "Maelle: Clases y Tipos",
        "scope": [
            "entity.name.type",
            "entity.name.class",
            "support.type",
            "support.class"
        ],
        "settings": { "foreground": "#b59a68", "fontStyle": "bold" }
      },
      {
        "name": "Maelle: Etiquetas (HTML/XML)",
        "scope": "entity.name.tag",
        "settings": { "foreground": "#b85151" }
      },
      {
        "name": "Maelle: Constantes",
        "scope": "constant.other",
        "settings": { "foreground": "#e6c47a" }
      }
    ]
  },

  "editor.semanticHighlighting.enabled": true
}