  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6e6a6a", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#b85151", "fontStyle": "bold" }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": { "foreground": "#659e7a" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#e6c47a", "fontStyle": "italic" }
    },
    {
      "scope": "variable",
      "settings": { "foreground": "#d0dbdc" }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#a86b61" }
    },
    {
      "scope": "entity.name.type",
      "settings": { "foreground": "#b59a68" }
    },
    {
      "scope": ["markup.bold", "markup.heading"],
      "settings": { "foreground": "#d43c3c", "fontStyle": "bold" }
    },
    {
      "scope": "markup.italic",
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": "markup.inserted",
      "settings": { "foreground": "#6f8f72" }
    },
    {
      "scope": "markup.deleted",
      "settings": { "foreground": "#ff4d4d" }
    }
  ],
  "editor.semanticHighlighting.enabled": true,
    "editor.tokenColorCustomizations": {
      "textMateRules": [
        {
          "name": "Alicia: Keywords (public, static, int)",
          "scope": [
            "keyword",
            "storage.type",
            "storage.modifier",
            "keyword.control"
          ],
            "settings": {
            "foreground": "#b85151",
            "fontStyle": "bold"
          }
        },
        {
          "name": "Alicia: Nombre de la función (suma)",
          "scope": [
            "entity.name.function",
            "variable.function",
            "support.function"
          ],
          "settings": {
            "foreground": "#e6c47a",
            "fontStyle": "italic"
          }
        },
        {
          "name": "Alicia: Variables y parámetros",
          "scope": [
            "variable",
            "variable.other",
            "variable.parameter"
          ],
          "settings": {
            "foreground": "#d0dbdc"
          }
        },
        {
          "name": "Alicia: Números y constantes",
          "scope": ["constant.numeric", "constant.language"],
          "settings": {
            "foreground": "#a86b61"
          }
        },
        {
          "name": "Alicia: Operadores y puntuación",
          "scope": [
            "keyword.operator",
            "punctuation",
            "meta.brace",
            "punctuation.definition.parameters"
          ],
          "settings": {
            "foreground": "#8c7a6b"
          }
        },
        {
          "name": "Forzar color comentarios",
          "scope": "comment",
          "settings": {
            "foreground": "#6e6a6a",
            "fontStyle": "italic"
          }
        }
      ]
    }
}